# ── Fridgge Environment Variables ─────────────────────────────────────────────
# Skopiuj ten plik jako .env i uzupełnij wartości.
# NIGDY nie commituj pliku .env do repozytorium!
# cp .env.example .env

# ── USDA FoodData Central ─────────────────────────────────────────────────────
# Pobierz darmowy klucz: https://fdc.nal.usda.gov/api-guide.html
# Używany tylko jako fallback gdy Open Food Facts nie zwróci wyników.
USDA_API_KEY=DEMO_KEY

# ── Generatywne AI (LLM dla przepisów) ───────────────────────────────────────
# Wybierz jedno z poniższych:

# Google Gemini API: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# LUB OpenAI API: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key_here
